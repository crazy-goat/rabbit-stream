{
    "name": "crazy-goat/rabbit-stream",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "CrazyGoat\\RabbitStream\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Hałas Piotr",
            "email": "halaspiotr@gmail.com"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "CrazyGoat\\RabbitStream\\Tests\\": "tests/"
        }
    },
    "require": {
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpcsstandards/php_codesniffer": "^3.9"
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml.dist",
        "lint:fix": "phpcbf --standard=phpcs.xml.dist",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:e2e": "phpunit --testsuite e2e"
    }
}
